{
  "rules": {
    "chats": {
      "$conversationId": {
        ".read": "auth.uid != null && data.child('participants').hasChild(auth.uid)",
        ".write": "auth.uid != null && (newData.child('participants').hasChild(auth.uid) || data.child('participants').hasChild(auth.uid))",
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['senderId', 'content'])",
            "senderId": {
              ".validate": "newData.val() === auth.uid"
            },
            "content": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
            }
          }
        },
        "participants": {
          ".validate": "newData.val() === data.val()"
        }
      }
    },
    "userChats": {
      "$uid": {
        ".read": "auth.uid == $uid",
        ".write": "auth.uid == $uid"
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth.uid != null",
        ".write": "auth.uid === $uid"
      }
    }
  }
}
